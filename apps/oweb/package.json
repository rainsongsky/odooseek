{
  "name": "oweb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --bun node_modules/.bin/vite",
    "build": "bun --bun node_modules/.bin/tsc -b && bun --bun node_modules/.bin/vite build",
    "test": "bun --bun node_modules/.bin/vitest run",
    "test:watch": "bun --bun node_modules/.bin/vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "lint": "biome check ../../",
    "format": "biome format --write ../../",
    "preview": "bun --bun node_modules/.bin/vite preview"
  },
  "dependencies": {
    "@odooseek/odoo-client": "file:../../packages/odoo-client",
    "@odooseek/odoo-types": "file:../../packages/odoo-types",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "date-fns": "^4.3.0",
    "dompurify": "^3.4.7",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "use-intl": "^4.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "postcss-prefix-selector": "^2.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
