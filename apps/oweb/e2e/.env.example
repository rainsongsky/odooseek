# Copy to e2e/.env.local or export before `bun run e2e`
# Prerequisites: Odoo (:8069), odoo-web-server (:3000), oweb dev (:5173) — or set E2E_BASE_URL to BFF after `bun run oweb:build`

E2E_BASE_URL=http://localhost:5173
E2E_DB=odoo19
E2E_LOGIN=admin@admin.com
E2E_PASSWORD=admin

# Skip starting Vite when servers are already up
# E2E_SKIP_WEBSERVER=1
