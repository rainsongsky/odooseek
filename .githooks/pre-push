#!/usr/bin/env bash
# pre-push hook — run local CI before pushing.
# Bypass with: git push --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()  { echo -e "${YELLOW}[pre-push]${NC} $*"; }
pass() { echo -e "${GREEN}[pre-push]${NC} $*"; }
fail() { echo -e "${RED}[pre-push]${NC} $*" >&2; }

export RUSTFLAGS="-D warnings"
export RUSTDOCFLAGS="-D warnings"

FAILED=0
START=$SECONDS

run_step() {
  local label="$1"
  shift
  log "[$label] running..."
  if "$@" > /tmp/odooseek-pre-push.log 2>&1; then
    pass "[$label] ok"
  else
    fail "[$label] FAILED — showing tail:"
    tail -20 /tmp/odooseek-pre-push.log >&2
    FAILED=1
    return 1
  fi
}

# ── Rust CI ───────────────────────────────────────────────

run_step "fmt"    cargo fmt --check --all              || exit 1
run_step "clippy" cargo clippy --all-targets --no-deps || exit 1
run_step "build"  cargo build --workspace              || exit 1
run_step "doc"    cargo doc --workspace --no-deps       || exit 1
run_step "test"   cargo test --workspace -- --test-threads=1 || exit 1

# ── TypeScript CI (only when oweb code changed) ──────────

OWEB_CHANGED=$(git diff --name-only HEAD@{push}...HEAD -- 'apps/oweb/' 2>/dev/null | head -1 || true)

if [ -n "$OWEB_CHANGED" ]; then
  if [ -d "apps/oweb" ]; then
    run_step "ts-lint" sh -c 'cd apps/oweb && node_modules/@biomejs/cli-linux-x64/biome check src/' || exit 1
  fi
fi

ELAPSED=$(( SECONDS - START ))

if [ "$FAILED" -eq 0 ]; then
  pass "all checks passed (${ELAPSED}s)"
  exit 0
else
  fail "push blocked — fix errors above, then retry (or --no-verify to bypass)"
  exit 1
fi
