{
  "name": "@odooseek/odoo-client",
  "version": "0.1.0",
  "description": "Framework-agnostic Odoo 19 CE JSON-RPC client with view XML parser",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./xml-parser": {
      "import": "./src/xml-parser.ts",
      "types": "./src/xml-parser.ts"
    }
  },
  "files": ["src/"],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["odoo", "json-rpc", "erp", "xml-parser", "bff"],
  "license": "MIT",
  "devDependencies": {
    "@vitest/ui": "^4.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^5.0",
    "vitest": "^4.0"
  }
}
